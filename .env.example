# Copy to .env for local development:
#   copy .env.example .env
#
# Vite only exposes variables prefixed with VITE_

# --- Local dev (npm run dev) ---
# Leave VITE_API_BASE_URL unset — requests go to /api and Vite proxies to the backend.
# VITE_API_BASE_URL=http://127.0.0.1:8000

# Backend URL for the dev proxy (default: http://127.0.0.1:8000)
# VITE_DEV_API_TARGET=http://127.0.0.1:8000

# --- Production build (npm run build) ---
# Required at build time — set in CI/hosting or uncomment for a local prod build:
# VITE_API_BASE_URL=https://your-api.example.com
